<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".views.CalculoBaseNumerica"
    android:background="@color/CinzaEscuro">

    <View
        android:id="@+id/View"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="72dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:background="@color/CianoClaro"/>

    <TextView
        android:id="@+id/textInformaBaseEntrada"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="@id/View"
        app:layout_constraintEnd_toStartOf="@id/imgSeta"
        app:layout_constraintTop_toTopOf="@id/imgSeta"
        app:layout_constraintBottom_toTopOf="@id/txtInformaValorEndrada"
        android:textColor="@color/CianoClaro"
        android:textStyle="bold"
        android:textSize="14dp"/>

    <TextView
        android:id="@+id/txtInformaValorEndrada"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="@id/textInformaBaseEntrada"
        app:layout_constraintEnd_toEndOf="@id/textInformaBaseEntrada"
        app:layout_constraintBottom_toBottomOf="@id/imgSeta"
        app:layout_constraintTop_toBottomOf="@id/textInformaBaseEntrada"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="12dp"/>

    <ImageView
        android:id="@+id/imgSeta"
        android:layout_width="30dp"
        android:layout_height="30dp"
        app:layout_constraintStart_toEndOf="@id/textInformaBaseEntrada"
        app:layout_constraintEnd_toStartOf="@id/textInformaBaseSaida"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/View"
        android:layout_marginTop="24dp"
        android:src="@drawable/arrow"/>

    <TextView
        android:id="@+id/textInformaBaseSaida"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toEndOf="@id/imgSeta"
        app:layout_constraintEnd_toEndOf="@id/View"
        app:layout_constraintTop_toTopOf="@id/imgSeta"
        app:layout_constraintBottom_toTopOf="@id/textInformaValorSaida"
        android:textColor="@color/CianoClaro"
        android:textStyle="bold"
        android:textSize="14dp"/>


    <TextView
        android:id="@+id/textInformaValorSaida"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="@id/textInformaBaseSaida"
        app:layout_constraintEnd_toEndOf="@id/textInformaBaseSaida"
        app:layout_constraintTop_toBottomOf="@id/textInformaBaseSaida"
        app:layout_constraintBottom_toBottomOf="@id/imgSeta"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="12dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/nestedScrowViewPassoAPasso"
        android:layout_marginBottom="16dp"
        android:text="@string/txtMostrarResolucao"
        android:textStyle="bold"
        android:textColor="@color/CianoClaro"
        android:textSize="16dp"/>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrowViewPassoAPasso"
        android:layout_width="match_parent"
        android:layout_height="350dp"
        app:layout_constraintTop_toTopOf="@id/View"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="64dp">

        <TextView
            android:id="@+id/txtPassoapasso"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:textStyle="bold"/>

    </androidx.core.widget.NestedScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/nestedScrowViewPassoAPasso"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="8dp"
        android:background="@color/CianoClaro"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/nestedScrowViewPassoAPasso"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="8dp"
        android:background="@color/CianoClaro"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonCopiar"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/nestedScrowViewPassoAPasso"
        android:layout_marginBottom="48dp"
        android:text="@string/copiar"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:backgroundTint="@color/AzulClaro"
        app:cornerRadius="12dp"
        app:rippleColor="@color/Azul"
        android:textAllCaps="false"/>

</androidx.constraintlayout.widget.ConstraintLayout>