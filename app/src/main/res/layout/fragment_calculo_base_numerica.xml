<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.basesNumericasFragments.CalculoBaseNumericaFragment"
    android:background="@color/CinzaEscuro">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDadosPassoAPasso"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginStart="12sp"
        android:layout_marginEnd="12sp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/background_card"
            android:padding="16dp">

            <TextView
                android:id="@+id/txtTopPassoAPasso"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:text="@string/txtConvPassoaPasso"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="18sp"/>


            <TextView
                android:id="@+id/textInformaBaseEntrada"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/imgSeta"
                app:layout_constraintTop_toTopOf="@id/imgSeta"
                app:layout_constraintBottom_toTopOf="@id/txtInformaValorEndrada"
                android:text="Base Entrada"
                android:textColor="@color/CianoClaro"
                android:textStyle="bold"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/txtInformaValorEndrada"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/imgSeta"
                app:layout_constraintBottom_toBottomOf="@id/imgSeta"
                app:layout_constraintTop_toBottomOf="@id/textInformaBaseEntrada"
                android:text="Valor Entrada"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="16sp"/>

            <ImageView
                android:id="@+id/imgSeta"
                android:layout_width="30dp"
                android:layout_height="30dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/txtTopPassoAPasso"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginTop="20sp"
                android:src="@drawable/double_arrow"/>


            <TextView
                android:id="@+id/textInformaBaseSaida"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toEndOf="@id/imgSeta"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/imgSeta"
                app:layout_constraintBottom_toTopOf="@id/textInformaValorSaida"
                android:text="Base Saída"
                android:textColor="@color/CianoClaro"
                android:textStyle="bold"
                android:textSize="14sp"/>


            <TextView
                android:id="@+id/textInformaValorSaida"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toEndOf="@id/imgSeta"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/textInformaBaseSaida"
                app:layout_constraintBottom_toBottomOf="@id/imgSeta"
                android:text="Valor Saída"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="16sp"/>


        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>


    <View
        android:id="@+id/div_passoAPasso"
        android:layout_width="match_parent"
        android:layout_height="2sp"
        app:layout_constraintTop_toBottomOf="@id/cardDadosPassoAPasso"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="12sp"
        android:layout_marginEnd="12sp"
        android:layout_marginTop="16dp"
        android:background="@drawable/degrade_background_div"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardRespostaPassoAPasso"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/div_passoAPasso"
        android:layout_marginTop="16dp"
        android:layout_marginStart="12sp"
        android:layout_marginEnd="12sp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/background_card"
            android:padding="16dp">

            <TextView
                android:id="@+id/txtResolucaoPassoAPasso"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:text="@string/txtMostrarResolucao"
                android:textStyle="bold"
                android:textColor="@color/CianoClaro"
                android:textSize="16sp"/>

            <androidx.core.widget.NestedScrollView
                android:id="@+id/nestedScrowViewPassoAPasso"
                android:layout_width="match_parent"
                android:layout_height="350dp"
                app:layout_constraintTop_toBottomOf="@id/txtResolucaoPassoAPasso"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="16sp">

                <TextView
                    android:id="@+id/txtPassoapasso"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"/>

            </androidx.core.widget.NestedScrollView>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonCopiar"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardRespostaPassoAPasso"
        android:layout_marginBottom="48dp"
        android:text="@string/copiar"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:backgroundTint="@color/AzulClaro"
        app:cornerRadius="12dp"
        app:rippleColor="@color/Azul"
        android:textAllCaps="false"/>

</androidx.constraintlayout.widget.ConstraintLayout>